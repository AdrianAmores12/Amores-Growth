<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<title>Amores Growth — Growth Partner</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,300&display=swap" rel="stylesheet">
<style>
:root {
  --navy: #0a1628;
  --navy-mid: #0f2044;
  --navy-light: #1a3260;
  --titanium: #8a9bb0;
  --titanium-light: #b8c5d4;
  --white: #f4f7fb;
  --black: #060d18;
  --accent: #c8d8f0;
  --border: rgba(100,160,255,0.12);
  --border-hover: rgba(100,160,255,0.35);
}

*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
html { scroll-behavior: smooth; font-size: 16px; }

body {
  background: var(--black);
  color: var(--white);
  font-family: 'DM Sans', sans-serif;
  overflow-x: hidden;
  -webkit-font-smoothing: antialiased;
}

/* CURSOR - desktop only */
@media (hover: hover) {
  body { cursor: none; }
  .cursor {
    width: 8px; height: 8px;
    background: var(--accent);
    border-radius: 50%;
    position: fixed; top: 0; left: 0;
    pointer-events: none; z-index: 9999;
    mix-blend-mode: screen;
    transition: transform 0.1s;
  }
  .cursor-ring {
    width: 32px; height: 32px;
    border: 1px solid rgba(200,216,240,0.35);
    border-radius: 50%;
    position: fixed; top: 0; left: 0;
    pointer-events: none; z-index: 9998;
  }
}

/* NAV */
nav {
  position: fixed; top: 0; left: 0; right: 0; z-index: 200;
  display: flex; justify-content: space-between; align-items: center;
  padding: 18px 5vw;
  background: rgba(6,13,24,0.92);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border-bottom: 1px solid rgba(100,160,255,0.06);
}
.logo {
  font-family: 'Syne', sans-serif;
  font-weight: 800; font-size: 1.1rem;
  letter-spacing: 0.04em; color: var(--white);
  text-decoration: none;
}
.logo span { color: var(--titanium-light); }

.nav-links {
  list-style: none; display: flex; gap: 32px; align-items: center;
}
.nav-links a {
  color: var(--titanium); text-decoration: none;
  font-size: 0.8rem; letter-spacing: 0.1em; text-transform: uppercase;
  transition: color 0.25s;
}
.nav-links a:hover { color: var(--white); }
.nav-cta {
  border: 1px solid rgba(100,160,255,0.3) !important;
  color: var(--white) !important;
  padding: 9px 20px !important;
  border-radius: 2px;
  transition: all 0.25s !important;
}
.nav-cta:hover { background: var(--navy-light) !important; border-color: var(--accent) !important; }

/* hamburger mobile */
.hamburger {
  display: none; flex-direction: column; gap: 5px;
  background: none; border: none; cursor: pointer; padding: 4px;
}
.hamburger span {
  display: block; width: 22px; height: 1.5px;
  background: var(--titanium-light); border-radius: 2px;
  transition: all 0.3s;
}
.mobile-menu {
  display: none; position: fixed; top: 57px; left: 0; right: 0;
  background: rgba(6,13,24,0.98);
  border-bottom: 1px solid var(--border);
  padding: 24px 5vw; z-index: 199; flex-direction: column; gap: 20px;
}
.mobile-menu.open { display: flex; }
.mobile-menu a {
  color: var(--titanium); text-decoration: none;
  font-size: 0.9rem; letter-spacing: 0.1em; text-transform: uppercase;
  padding: 8px 0; border-bottom: 1px solid var(--border);
  transition: color 0.2s;
}
.mobile-menu a:last-child { border-bottom: none; color: var(--white); }

/* HERO */
.hero {
  min-height: 100svh;
  display: flex; align-items: center;
  position: relative; overflow: hidden;
  padding: 100px 5vw 60px;
}
.hero-bg {
  position: absolute; inset: 0;
  background:
    radial-gradient(ellipse 70% 60% at 65% 40%, rgba(15,32,68,0.85) 0%, transparent 65%),
    radial-gradient(ellipse 40% 40% at 15% 80%, rgba(10,22,40,0.5) 0%, transparent 60%),
    var(--black);
}

/* 3D Sphere */
.sphere-wrap {
  position: absolute;
  right: -60px; top: 50%;
  transform: translateY(-50%);
  width: min(55vw, 560px); height: min(55vw, 560px);
  pointer-events: none;
}
.sphere {
  width: 100%; height: 100%; border-radius: 50%;
  background: radial-gradient(circle at 33% 33%,
    rgba(100,150,220,0.22) 0%,
    rgba(15,32,68,0.78) 38%,
    rgba(6,13,24,0.96) 68%
  );
  box-shadow:
    inset -50px -50px 100px rgba(0,0,0,0.75),
    inset 25px 25px 70px rgba(100,160,255,0.07),
    0 0 100px rgba(30,70,150,0.25),
    0 0 260px rgba(10,30,80,0.35);
  animation: s-float 9s ease-in-out infinite;
  position: relative;
}
.sphere::before {
  content: '';
  position: absolute; top: 11%; left: 17%;
  width: 26%; height: 16%;
  background: radial-gradient(ellipse, rgba(180,210,255,0.15) 0%, transparent 70%);
  border-radius: 50%; filter: blur(7px);
}
.sphere-ring {
  position: absolute; inset: 0; border-radius: 50%;
  border: 1px solid rgba(100,160,255,0.07);
  animation: s-spin 22s linear infinite;
}
.sphere-ring-2 {
  position: absolute; inset: 12%; border-radius: 50%;
  border: 1px solid rgba(100,160,255,0.05);
  animation: s-spin 30s linear infinite reverse;
}
.orbit-ring {
  position: absolute; border-radius: 50%;
  border: 1px solid rgba(100,160,255,0.09);
}
.orbit-ring-1 {
  width: 130%; height: 130%;
  top: 50%; left: 50%;
  transform: translate(-50%,-50%) rotateX(74deg);
  animation: o-spin 20s linear infinite;
}
.orbit-ring-2 {
  width: 155%; height: 155%;
  top: 50%; left: 50%;
  transform: translate(-50%,-50%) rotateX(74deg) rotateZ(50deg);
  animation: o-spin 28s linear infinite reverse;
  border-color: rgba(100,160,255,0.05);
}
.orbit-dot {
  position: absolute; width: 5px; height: 5px;
  background: var(--accent); border-radius: 50%;
  top: -2.5px; left: 50%;
  box-shadow: 0 0 10px var(--accent);
}
@keyframes s-float { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-18px)} }
@keyframes s-spin { from{transform:rotate(0)} to{transform:rotate(360deg)} }
@keyframes o-spin {
  from { transform: translate(-50%,-50%) rotateX(74deg) rotate(0deg); }
  to   { transform: translate(-50%,-50%) rotateX(74deg) rotate(360deg); }
}

/* Particles */
.particle {
  position: absolute; width: 2px; height: 2px;
  background: var(--accent); border-radius: 50%; opacity: 0;
  animation: pdrift linear infinite;
}
@keyframes pdrift {
  0%   { transform: translateY(0) translateX(0); opacity: 0; }
  10%  { opacity: 0.5; }
  90%  { opacity: 0.2; }
  100% { transform: translateY(-180px) translateX(30px); opacity: 0; }
}

.hero-content { position: relative; z-index: 2; max-width: 600px; width: 100%; }
.badge {
  display: inline-flex; align-items: center; gap: 8px;
  background: rgba(100,160,255,0.07); border: 1px solid rgba(100,160,255,0.18);
  padding: 7px 16px; border-radius: 2px;
  font-size: 0.7rem; letter-spacing: 0.16em; text-transform: uppercase;
  color: var(--titanium-light); margin-bottom: 28px;
  opacity: 0; animation: fadeup 0.7s ease forwards 0.15s;
}
.badge::before {
  content: ''; width: 5px; height: 5px;
  background: var(--accent); border-radius: 50%;
  box-shadow: 0 0 7px var(--accent);
  animation: bpulse 2s ease infinite;
}
@keyframes bpulse { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:0.4;transform:scale(0.7)} }

.hero h1 {
  font-family: 'Syne', sans-serif;
  font-size: clamp(2.6rem, 5.5vw, 5rem);
  font-weight: 800; line-height: 1.03; letter-spacing: -0.03em;
  margin-bottom: 24px;
  opacity: 0; animation: fadeup 0.7s ease forwards 0.3s;
}
.hero h1 em { font-style: normal; color: var(--titanium-light); }
.hero h1 .outline {
  display: block; color: transparent;
  -webkit-text-stroke: 1px rgba(200,216,240,0.35);
}
.hero-sub {
  font-size: clamp(0.95rem, 2vw, 1.05rem);
  line-height: 1.72; color: var(--titanium);
  max-width: 500px; margin-bottom: 40px; font-weight: 300;
  opacity: 0; animation: fadeup 0.7s ease forwards 0.45s;
}
.hero-actions {
  display: flex; gap: 14px; align-items: center; flex-wrap: wrap;
  opacity: 0; animation: fadeup 0.7s ease forwards 0.6s;
}
@keyframes fadeup {
  from { opacity:0; transform:translateY(28px); }
  to   { opacity:1; transform:translateY(0); }
}

/* BUTTONS */
.btn {
  display: inline-flex; align-items: center; gap: 8px;
  text-decoration: none; border-radius: 2px;
  font-family: 'Syne', sans-serif; font-weight: 600;
  font-size: 0.82rem; letter-spacing: 0.1em; text-transform: uppercase;
  transition: all 0.3s; position: relative; overflow: hidden;
}
.btn-solid {
  background: var(--navy-light); color: var(--white);
  padding: 14px 30px;
  border: 1px solid rgba(100,160,255,0.25);
}
.btn-solid:hover {
  border-color: var(--accent); transform: translateY(-2px);
  box-shadow: 0 8px 28px rgba(20,60,130,0.45);
}
.btn-ghost-link {
  color: var(--titanium); background: none; border: none;
  padding: 14px 0; font-size: 0.82rem;
}
.btn-ghost-link:hover { color: var(--white); }
.btn-ghost-link svg { transition: transform 0.3s; }
.btn-ghost-link:hover svg { transform: translateX(5px); }

/* SECTION BASE */
.section { padding: clamp(64px, 10vw, 120px) 5vw; }
.inner { max-width: 1160px; margin: 0 auto; }

.eyebrow {
  font-size: 0.7rem; letter-spacing: 0.2em; text-transform: uppercase;
  color: var(--titanium); margin-bottom: 14px;
  display: flex; align-items: center; gap: 10px;
}
.eyebrow::before {
  content: ''; display: block; width: 26px; height: 1px;
  background: var(--titanium); flex-shrink: 0;
}
.section-title {
  font-family: 'Syne', sans-serif;
  font-size: clamp(1.8rem, 3.5vw, 3rem);
  font-weight: 700; line-height: 1.1; letter-spacing: -0.02em;
  margin-bottom: 20px;
}
.section-sub {
  font-size: clamp(0.92rem, 1.8vw, 1rem);
  line-height: 1.75; color: var(--titanium); font-weight: 300;
  max-width: 540px;
}

/* WHAT */
.what-grid {
  display: grid; grid-template-columns: 1fr 1fr;
  gap: clamp(40px, 6vw, 80px); align-items: center;
}
.what-text p { color: var(--titanium); line-height: 1.8; font-weight: 300; font-size: 1rem; }
.what-text p + p { margin-top: 14px; }
.pullquote {
  margin-top: 28px; padding: 16px 20px;
  background: rgba(100,160,255,0.05);
  border-left: 2px solid rgba(100,160,255,0.35);
  color: var(--titanium-light); font-size: 0.9rem;
  font-style: italic; line-height: 1.65;
}

/* 3D Cube */
.cube-scene {
  perspective: 700px;
  display: flex; justify-content: center; align-items: center;
  height: clamp(220px, 30vw, 320px);
}
.cube {
  width: clamp(130px, 16vw, 170px);
  height: clamp(130px, 16vw, 170px);
  position: relative; transform-style: preserve-3d;
  animation: cube-spin 15s linear infinite;
}
.cf {
  position: absolute;
  width: clamp(130px, 16vw, 170px);
  height: clamp(130px, 16vw, 170px);
  border: 1px solid rgba(100,160,255,0.18);
  background: rgba(15,32,68,0.55);
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  font-family: 'Syne', sans-serif;
  font-size: 0.65rem; font-weight: 700;
  letter-spacing: 0.1em; text-transform: uppercase;
  color: var(--titanium-light); gap: 8px;
}
.cf .fi { font-size: 1.6rem; }
.cf.front  { transform: translateZ(calc(clamp(130px,16vw,170px)/2)); }
.cf.back   { transform: translateZ(calc(-1 * clamp(130px,16vw,170px)/2)) rotateY(180deg); }
.cf.left   { transform: translateX(calc(-1 * clamp(130px,16vw,170px)/2)) rotateY(-90deg); }
.cf.right  { transform: translateX(calc(clamp(130px,16vw,170px)/2)) rotateY(90deg); }
.cf.top    { transform: translateY(calc(-1 * clamp(130px,16vw,170px)/2)) rotateX(90deg); }
.cf.bottom { transform: translateY(calc(clamp(130px,16vw,170px)/2)) rotateX(-90deg); }
@keyframes cube-spin { 0%{transform:rotateX(14deg) rotateY(0)} 100%{transform:rotateX(14deg) rotateY(360deg)} }

/* PROBLEMS → SOLUTION (sin / con) */
.comparison {
  background: linear-gradient(180deg, var(--black) 0%, var(--navy) 50%, var(--black) 100%);
}
.compare-grid {
  display: grid; grid-template-columns: 1fr 1fr;
  gap: 2px; margin-top: 56px;
  border: 1px solid var(--border);
}
.compare-col { padding: clamp(28px, 4vw, 48px); }
.compare-col.without {
  background: rgba(6,13,24,0.8);
  border-right: 1px solid var(--border);
}
.compare-col.with {
  background: rgba(15,32,68,0.45);
  position: relative;
}
.compare-col.with::before {
  content: '';
  position: absolute; top: 0; left: 0; right: 0; height: 2px;
  background: linear-gradient(to right, transparent, rgba(100,160,255,0.5), transparent);
}
.compare-head {
  font-family: 'Syne', sans-serif;
  font-size: 0.72rem; font-weight: 700; letter-spacing: 0.18em;
  text-transform: uppercase; margin-bottom: 24px;
}
.compare-col.without .compare-head { color: var(--titanium); }
.compare-col.with .compare-head { color: var(--titanium-light); }
.compare-item {
  display: flex; gap: 12px; align-items: flex-start;
  margin-bottom: 18px; font-size: 0.92rem;
  line-height: 1.6; color: var(--titanium); font-weight: 300;
}
.compare-item .dot {
  width: 5px; height: 5px; border-radius: 50%;
  margin-top: 7px; flex-shrink: 0;
}
.without .dot { background: rgba(100,130,160,0.4); }
.with .dot { background: var(--accent); box-shadow: 0 0 6px var(--accent); }
.with .compare-item { color: var(--white); }

/* SERVICES */
.services-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16px; margin-top: 56px;
}
.service-card {
  background: linear-gradient(145deg, rgba(15,32,68,0.55), rgba(6,13,24,0.75));
  border: 1px solid var(--border);
  padding: clamp(24px, 3.5vw, 40px);
  border-radius: 2px; transition: all 0.4s;
  position: relative; overflow: hidden;
}
.service-card::after {
  content: '';
  position: absolute; top: 0; left: 0; right: 0; height: 1px;
  background: linear-gradient(to right, transparent, rgba(100,160,255,0.3), transparent);
  transform: scaleX(0); transition: transform 0.4s;
}
.service-card:hover { border-color: var(--border-hover); transform: translateY(-5px); box-shadow: 0 18px 55px rgba(0,0,0,0.5); }
.service-card:hover::after { transform: scaleX(1); }
.service-icon {
  width: 44px; height: 44px;
  background: rgba(100,160,255,0.07); border: 1px solid var(--border);
  border-radius: 50%; display: flex; align-items: center;
  justify-content: center; font-size: 1.2rem; margin-bottom: 20px;
}
.service-card h3 {
  font-family: 'Syne', sans-serif; font-size: 1rem; font-weight: 700;
  margin-bottom: 10px; color: var(--white);
}
.service-card p {
  font-size: 0.87rem; line-height: 1.7;
  color: var(--titanium); font-weight: 300;
}
.service-tag {
  display: inline-block; margin-top: 16px;
  font-size: 0.68rem; letter-spacing: 0.12em; text-transform: uppercase;
  color: rgba(100,160,255,0.6); font-weight: 600;
}

/* HOW */
.how-bg { background: var(--black); }
.how-intro { max-width: 580px; margin-bottom: 56px; }
.steps {
  display: grid; grid-template-columns: repeat(4,1fr);
  gap: 2px;
}
.step {
  background: rgba(15,32,68,0.35); border: 1px solid var(--border);
  padding: clamp(24px, 3vw, 40px) clamp(20px, 2.5vw, 30px);
  transition: all 0.35s; position: relative;
}
.step:hover { background: rgba(15,32,68,0.6); transform: translateY(-3px); }
.step-num {
  font-family: 'Syne', sans-serif;
  font-size: 2.4rem; font-weight: 800;
  color: rgba(100,160,255,0.1); line-height: 1;
  margin-bottom: 16px; letter-spacing: -0.04em;
}
.step h3 {
  font-family: 'Syne', sans-serif; font-size: 0.95rem;
  font-weight: 700; margin-bottom: 10px; color: var(--white);
}
.step p { font-size: 0.86rem; line-height: 1.68; color: var(--titanium); font-weight: 300; }

/* AUTOMATION highlight */
.automation-block {
  margin-top: 48px; padding: clamp(24px, 4vw, 48px);
  background: rgba(15,32,68,0.4); border: 1px solid var(--border);
  display: grid; grid-template-columns: 1fr 1fr; gap: 48px; align-items: center;
}
.auto-label {
  display: inline-flex; align-items: center; gap: 7px;
  font-size: 0.68rem; letter-spacing: 0.16em; text-transform: uppercase;
  color: var(--titanium-light); margin-bottom: 14px;
}
.auto-label::before {
  content: ''; width: 5px; height: 5px;
  background: var(--accent); border-radius: 50%;
  box-shadow: 0 0 7px var(--accent);
  animation: bpulse 2s ease infinite;
}
.auto-title {
  font-family: 'Syne', sans-serif; font-size: clamp(1.3rem,2.5vw,1.9rem);
  font-weight: 700; line-height: 1.2; letter-spacing: -0.02em;
  margin-bottom: 14px;
}
.auto-desc { font-size: 0.9rem; line-height: 1.75; color: var(--titanium); font-weight: 300; }
.auto-tags { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 20px; }
.auto-tag {
  padding: 5px 12px; border: 1px solid var(--border);
  font-size: 0.72rem; letter-spacing: 0.08em;
  color: var(--titanium-light); border-radius: 2px;
}
.auto-flow {
  display: flex; flex-direction: column; gap: 3px;
}
.flow-node {
  display: flex; align-items: center; gap: 14px;
  padding: 12px 16px;
  background: rgba(6,13,24,0.6); border: 1px solid var(--border);
  border-radius: 2px; font-size: 0.85rem; color: var(--titanium-light);
  font-weight: 400;
}
.flow-node .fn-icon { font-size: 1.1rem; flex-shrink: 0; }
.flow-arrow {
  text-align: center; color: rgba(100,160,255,0.3);
  font-size: 0.8rem; line-height: 1.2;
}

/* STORY */
.story-section {
  background: linear-gradient(180deg, var(--black), var(--navy) 45%, var(--navy-mid) 72%, var(--black));
  position: relative; overflow: hidden;
}
.bg-18 {
  position: absolute; right: -10px; top: 50%;
  transform: translateY(-50%);
  font-family: 'Syne', sans-serif; font-size: 28vw;
  font-weight: 800; color: rgba(100,160,255,0.02);
  pointer-events: none; user-select: none; line-height: 1;
}
.story-inner { max-width: 880px; margin: 0 auto; position: relative; z-index: 2; }
.story-quote {
  font-family: 'Syne', sans-serif;
  font-size: clamp(1.4rem, 2.8vw, 2.2rem);
  font-weight: 600; line-height: 1.42; letter-spacing: -0.02em;
  border-left: 3px solid rgba(100,160,255,0.4);
  padding-left: clamp(20px, 4vw, 40px); margin-bottom: 56px;
}
.story-quote em { font-style: italic; color: var(--titanium-light); }
.story-body { display: grid; grid-template-columns: 180px 1fr; gap: 48px; align-items: start; }
.story-aside { position: sticky; top: 100px; }
.story-age {
  font-family: 'Syne', sans-serif; font-size: 4.5rem;
  font-weight: 800; color: transparent;
  -webkit-text-stroke: 1px rgba(100,160,255,0.28);
  line-height: 1; margin-bottom: 6px; letter-spacing: -0.05em;
}
.story-name { font-family: 'Syne', sans-serif; font-weight: 700; font-size: 1rem; margin-bottom: 3px; }
.story-role { font-size: 0.75rem; color: var(--titanium); letter-spacing: 0.1em; text-transform: uppercase; }
.story-text p {
  font-size: clamp(0.92rem, 1.8vw, 1rem); line-height: 1.85;
  color: var(--titanium); font-weight: 300; margin-bottom: 18px;
}
.story-text p strong { color: var(--white); font-weight: 500; }

/* CTA */
.cta-section {
  background: var(--black); text-align: center;
  padding: clamp(80px, 12vw, 140px) 5vw; position: relative; overflow: hidden;
}
.cta-glow {
  position: absolute; inset: 0;
  background: radial-gradient(ellipse 55% 45% at 50% 50%, rgba(15,32,68,0.75), transparent);
}
.cta-inner { position: relative; z-index: 2; max-width: 660px; margin: 0 auto; }
.cta-inner .eyebrow { justify-content: center; }
.cta-inner .eyebrow::before { display: none; }
.cta-inner .eyebrow::after {
  content: ''; display: block; width: 26px; height: 1px;
  background: var(--titanium);
}
.cta-section h2 {
  font-family: 'Syne', sans-serif;
  font-size: clamp(2.2rem, 4.5vw, 3.8rem);
  font-weight: 800; letter-spacing: -0.03em; line-height: 1.1;
  margin-bottom: 20px;
}
.cta-section > .cta-inner > p {
  color: var(--titanium); font-size: clamp(0.92rem, 1.8vw, 1.02rem);
